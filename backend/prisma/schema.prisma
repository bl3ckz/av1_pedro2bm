generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" 
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Modelo de Filme — Sistema PedroCine
model Movie {
  id                Int      @id @default(autoincrement())
  titulo            String   @db.VarChar(255)
  genero            String   @db.VarChar(100)
  descricao         String?  @db.LongText
  diretor           String   @db.VarChar(255)
  elenco            String?  @db.LongText
  duracao           Int      // em minutos
  anoLancamento     Int
  classificacao     String   @db.VarChar(50)
  imagem            String?  @db.LongText
  nota              Float    @default(0)
  disponivel        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("movies")
}
